/* ================= AUTH ================= */

const AuthContext = createContext();

function AuthProvider({ children }) {
  const [user, setUser] = useState(() =>
    JSON.parse(localStorage.getItem("user")) || null
  );

  const login = (name) => {
    const newUser = {
      name,
      plan: "free",
      usedThisMonth: 0,
      lastResetMonth: new Date().getMonth()
    };

    setUser(newUser);
    localStorage.setItem("user", JSON.stringify(newUser));
  };

  const updateUser = (data) => {
    setUser((prev) => {
      const updated = { ...prev, ...data };
      localStorage.setItem("user", JSON.stringify(updated));
      return updated;
    });
  };

  const logout = () => {
    setUser(null);
    localStorage.removeItem("user");
  };

  return (
    <AuthContext.Provider value={{ user, login, updateUser, logout }}>
      {children}
    </AuthContext.Provider>
  );
}

const useAuth = () => useContext(AuthContext);

/* ================= PLANS ================= */

const PLANS = {
  free: { monthlyLimit: 100, model: "basic-ai" },
  gold: { monthlyLimit: 1000, model: "coming-soon" },
  diamond: { monthlyLimit: 1500, model: "coming-soon" },
  platinum: { monthlyLimit: 3000, model: "coming-soon" }
};

/* ================= BASIC AI ================= */

function basicAI(q) {
  const x = q.toLowerCase();

  if (x.includes("ohm")) return "V = IR";
  if (x.includes("newton")) return "F = ma";
  if (x.includes("work")) return "Work = Force × Distance";
  if (x.includes("limit")) return "Use standard limits";

  return "Basic AI: Upgrade coming soon for advanced answers.";
}

/* ================= WAITLIST STORAGE ================= */

function saveWaitlist(email) {
  const list = JSON.parse(localStorage.getItem("waitlist") || "[]");
  list.push({ email, date: new Date().toISOString() });
  localStorage.setItem("waitlist", JSON.stringify(list));
}

