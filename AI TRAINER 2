/* ================= AI ================= */

function AI() {
  const { user, updateUser } = useAuth();
  const [q, setQ] = useState("");
  const [chat, setChat] = useState([]);

  const plan = PLANS[user?.plan || "free"];

  const askAI = () => {
    if (!q) return;

    if (user.usedThisMonth >= plan.monthlyLimit) {
      setChat((p) => [...p, { role: "ai", text: "Limit reached. Upgrade soon." }]);
      return;
    }

    const answer = basicAI(q);

    setChat((p) => [...p, { role: "user", text: q }, { role: "ai", text: answer }]);

    updateUser({ usedThisMonth: user.usedThisMonth + 1 });

    setQ("");
  };

  return (
    <Card className="bg-white/10 text-white">
      <CardContent>

        <h2 className="text-xl font-bold">AI Tutor 🤖</h2>

        <p className="text-green-400">
          Usage: {user.usedThisMonth} / {plan.monthlyLimit}
        </p>

        <div className="h-40 overflow-auto border border-white/20 p-2 mt-2">
          {chat.map((c, i) => (
            <p key={i}>
              <b>{c.role}:</b> {c.text}
            </p>
          ))}
        </div>

        <Input
          className="bg-white/10 text-white mt-2"
          value={q}
          onChange={(e) => setQ(e.target.value)}
        />

        <Button
          className="mt-2 w-full bg-gradient-to-r from-blue-500 to-purple-600"
          onClick={askAI}
        >
          Ask AI
        </Button>

      </CardContent>
    </Card>
  );
}

